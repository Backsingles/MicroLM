{
  "name": "sft_valid_0p5_step1000",
  "description": "SFT run with a deterministic 0.5% validation split from MiniMind sft_t2t_mini.jsonl.",
  "tokenizer": {
    "vocab_path": "outputs/tokenizer_full_clean/vocab.json",
    "merges_path": "outputs/tokenizer_full_clean/merge.txt",
    "special_tokens": ["<|endoftext|>"]
  },
  "model": {
    "vocab_size": 6400,
    "context_length": 512,
    "d_model": 512,
    "num_layers": 8,
    "num_heads": 8,
    "d_ff": 1344,
    "rope_theta": 1000000.0,
    "use_rms_norm": true,
    "norm_mode": "pre",
    "ffn_type": "swiglu"
  },
  "optimizer": {
    "lr": 0.00001,
    "weight_decay": 0.1
  },
  "training": {
    "batch_size": 2,
    "max_steps": 1000,
    "eval_interval": 50,
    "save_interval": 200,
    "device": "cuda",
    "seed": 42,
    "num_workers": 8,
    "prefetch_factor": 4,
    "pin_memory": true,
    "out_dir": "outputs/sft_valid_0p5_step1000",
    "init_checkpoint": "outputs/pretrain_full_corpus/ckpt_final.pt",
    "resume": false
  },
  "data": {
    "train_data_path": "data/minimind_sft/gongjy/minimind_dataset/sft_t2t_train_995.jsonl",
    "valid_data_path": "data/minimind_sft/gongjy/minimind_dataset/sft_t2t_valid_005.jsonl",
    "system_prompt_ratio": 0.1,
    "eos_token": "<|endoftext|>"
  },
  "logging": {
    "wandb_project": "micro-lm",
    "run_name": "sft_valid_0p5_step1000",
    "mode": "disabled"
  }
}
